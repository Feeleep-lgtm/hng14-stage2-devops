# Redis
REDIS_IMAGE=redis:7.4-alpine
REDIS_SERVICE_NAME=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_QUEUE_NAME=job
REDIS_HEALTH_START_PERIOD=10

# API
API_SERVICE_NAME=api
API_HOST=0.0.0.0
API_PORT=8000
API_IMAGE=hng14/api:local

# Frontend
FRONTEND_SERVICE_NAME=frontend
FRONTEND_PORT=5000
API_TIMEOUT=5000
WORKER_IMAGE=hng14/worker:local
FRONTEND_IMAGE=hng14/frontend:local

# Health checks
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_RETRIES=3

# Compose resources
REDIS_CPU_LIMIT=0.50
REDIS_MEMORY_LIMIT=256m
API_CPU_LIMIT=0.50
API_MEMORY_LIMIT=256m
WORKER_CPU_LIMIT=0.50
WORKER_MEMORY_LIMIT=256m
FRONTEND_CPU_LIMIT=0.50
FRONTEND_MEMORY_LIMIT=256m

# Networking
STACK_NETWORK_NAME=hng14_internal
