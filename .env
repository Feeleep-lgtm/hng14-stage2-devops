# ============================================
# REDIS CONFIGURATION
# ============================================
# Redis host - change for Docker/K8s deployment
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis password - CHANGE THIS IN PRODUCTION!
REDIS_PASSWORD=your-strong-redis-password-here

# Redis queue name (can be overridden for different environments)
REDIS_QUEUE_NAME=job

# Redis connection pool settings
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# ============================================
# API SERVICE (FastAPI)
# ============================================
# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# API key for authentication - CHANGE THIS IN PRODUCTION!
API_KEY=your-secure-api-key-here-change-this

# Allowed CORS origins (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:5000,http://frontend:5000

# Rate limiting (requests per minute per IP)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============================================
# FRONTEND SERVICE (Node.js/Express)
# ============================================
# Frontend port
FRONTEND_PORT=5000

# API URL for frontend to connect
API_URL=http://localhost:8000

# Request timeout (milliseconds)
API_TIMEOUT=5000

# ============================================
# WORKER SERVICE
# ============================================
# Worker health check port
WORKER_HEALTH_PORT=8080

# Worker metrics port (Prometheus)
WORKER_METRICS_PORT=9090

# Job timeout in seconds
JOB_TIMEOUT_SECONDS=30

# Job retry configuration
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY_SECONDS=1

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
# Enable metrics collection (true/false)
ENABLE_METRICS=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable structured logging (JSON format)
STRUCTURED_LOGGING=false

# ============================================
# DOCKER/KUBERNETES SPECIFIC
# ============================================
# Set to 'production' for production optimizations
ENVIRONMENT=development

# Docker image and service names
REDIS_IMAGE=redis:7.4-alpine
REDIS_SERVICE_NAME=redis
API_SERVICE_NAME=api
WORKER_SERVICE_NAME=worker
FRONTEND_SERVICE_NAME=frontend
API_IMAGE=hng14/api:local
WORKER_IMAGE=hng14/worker:local
FRONTEND_IMAGE=hng14/frontend:local
STACK_NETWORK_NAME=hng14_internal

# ============================================
# HEALTH CHECKS
# ============================================
# Health check intervals (seconds)
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_RETRIES=3
REDIS_HEALTH_START_PERIOD=10

# ============================================
# DEAD LETTER QUEUE (DLQ)
# ============================================
# Maximum DLQ size before alerting
DLQ_MAX_SIZE=1000

# DLQ processing interval (seconds)
DLQ_PROCESS_INTERVAL=300

# ============================================
# PERFORMANCE TUNING
# ============================================
# Worker concurrency (number of worker processes)
WORKER_CONCURRENCY=1

# Redis connection pool max connections per worker
REDIS_POOL_MAX_CONNECTIONS=10

# Batch processing size (if implementing batch jobs)
BATCH_SIZE=100

# Container resource limits
REDIS_CPU_LIMIT=0.50
REDIS_MEMORY_LIMIT=256m
API_CPU_LIMIT=0.50
API_MEMORY_LIMIT=256m
WORKER_CPU_LIMIT=0.50
WORKER_MEMORY_LIMIT=256m
FRONTEND_CPU_LIMIT=0.50
FRONTEND_MEMORY_LIMIT=256m
